<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Secuencia para solicitudes de licitación -->
        <record id="seq_zonaweb_bidding_request" model="ir.sequence">
            <field name="name">Secuencia de Solicitudes de Licitación</field>
            <field name="code">zonaweb.bidding.request</field>
            <field name="prefix">BID/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Página web de inicio por defecto -->
        <record id="website_page_zonaweb_homepage" model="website.page">
            <field name="name">Inicio Zonaweb</field>
            <field name="website_published">True</field>
            <field name="website_indexed">True</field>
            <field name="url">/zonaweb-home</field>
            <field name="type">qweb</field>
            <field name="key">zonaweb_website.zonaweb_homepage</field>
        </record>

        <!-- Página de licitaciones -->
        <record id="website_page_bidding" model="website.page">
            <field name="name">Solicitar Licitación</field>
            <field name="website_published">True</field>
            <field name="website_indexed">True</field>
            <field name="url">/licencias</field>
            <field name="type">qweb</field>
            <field name="key">zonaweb_website.bidding_page</field>
        </record>
    </data>
</odoo>