<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vistas del modelo de solicitudes de licitación -->
        <record id="view_zonaweb_bidding_request_list" model="ir.ui.view">
            <field name="name">zonaweb.bidding.request.list</field>
            <field name="model">zonaweb.bidding.request</field>
            <field name="arch" type="xml">
                <list string="Solicitudes de Licitación">
                    <field name="name"/>
                    <field name="company_name"/>
                    <field name="contact_name"/>
                    <field name="email"/>
                    <field name="service_type"/>
                    <field name="state"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>
        
        <record id="view_zonaweb_bidding_request_form" model="ir.ui.view">
            <field name="name">zonaweb.bidding.request.form</field>
            <field name="model">zonaweb.bidding.request</field>
            <field name="arch" type="xml">
                <form string="Solicitud de Licitación">
                    <header>
                        <button name="action_confirm" type="object" string="Confirmar" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve" type="object" string="Aprobar" class="btn-success" invisible="state != 'confirmed'"/>
                        <button name="action_reject" type="object" string="Rechazar" class="btn-danger" invisible="state not in ['draft', 'confirmed']"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved,rejected"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_name"/>
                                <field name="contact_name"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </group>
                            <group>
                                <field name="service_type"/>
                                <field name="estimated_budget"/>
                                <field name="estimated_timeline"/>
                                <field name="company_sector"/>
                            </group>
                        </group>
                        <group>
                            <field name="project_description"/>
                            <field name="specific_requirements"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        
        <record id="view_zonaweb_bidding_request_kanban" model="ir.ui.view">
            <field name="name">zonaweb.bidding.request.kanban</field>
            <field name="model">zonaweb.bidding.request</field>
            <field name="arch" type="xml">
                <kanban string="Solicitudes de Licitación">
                    <field name="name"/>
                    <field name="company_name"/>
                    <field name="state"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.state.raw_value == 'approved' ? 'oe_kanban_color_4' : record.state.raw_value == 'rejected' ? 'oe_kanban_color_2' : ''}">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                        <div class="o_kanban_record_subtitle"><field name="company_name"/></div>
                                    </div>
                                    <div class="o_kanban_manage_button_section">
                                        <a class="o_kanban_manage_toggle_button" href="#" tabindex="-1">
                                            <i class="fa fa-ellipsis-v" role="img" aria-label="Manage" title="Manage"/>
                                        </a>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="contact_name"/><br/>
                                    <field name="email"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'confirmed': 'info', 'approved': 'success', 'rejected': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        
        <!-- Acción de ventana -->
        <record id="action_zonaweb_bidding_request" model="ir.actions.act_window">
            <field name="name">Solicitudes de Licitación</field>
            <field name="res_model">zonaweb.bidding.request</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crea tu primera solicitud de licitación
                </p>
                <p>
                    Las solicitudes de licitación se crearán automáticamente desde el formulario del sitio web.
                </p>
            </field>
        </record>
        
        <!-- Menú -->
        <menuitem id="menu_zonaweb_bidding" name="Licitaciones" parent="sale.sale_menu_root" sequence="10"/>
        <menuitem id="menu_zonaweb_bidding_requests" name="Solicitudes" parent="menu_zonaweb_bidding" action="action_zonaweb_bidding_request" sequence="10"/>
        
        <!-- Plantilla de email -->
        <record id="email_template_bidding_confirmation" model="mail.template">
            <field name="name">Confirmación de Solicitud de Licitación</field>
            <field name="model_id" ref="model_zonaweb_bidding_request"/>
            <field name="subject">Confirmación de Solicitud de Licitación - ${object.name}</field>
            <field name="email_from">${object.env.company.email or 'noreply@zonaweb.com'}</field>
            <field name="email_to">${object.email}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p>Estimado/a ${object.contact_name},</p>
                    <p>Gracias por tu interés en los servicios de Zonaweb. Hemos recibido tu solicitud de licitación con los siguientes detalles:</p>
                    <ul>
                        <li><strong>Número de referencia:</strong> ${object.name}</li>
                        <li><strong>Empresa:</strong> ${object.company_name}</li>
                        <li><strong>Tipo de servicio:</strong> ${object.service_type}</li>
                    </ul>
                    <p>Nuestro equipo revisará tu solicitud y te contactará en menos de 24 horas con una propuesta detallada.</p>
                    <p>Si tienes alguna pregunta, no dudes en contactarnos.</p>
                    <p>Atentamente,<br/>El equipo de Zonaweb</p>
                </div>
            </field>
        </record>
    </data>
</odoo>