<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista lista -->
        <record id="view_zonaweb_bidding_request_list" model="ir.ui.view">
            <field name="name">zonaweb.bidding.request.list</field>
            <field name="model">zonaweb.bidding.request</field>
            <field name="arch" type="xml">
                <list string="Solicitudes de Licitación">
                    <field name="name"/>
                    <field name="company_name"/>
                    <field name="contact_name"/>
                    <field name="email"/>
                    <field name="service_type"/>
                    <field name="state" widget="badge"
                        decoration-success="state == 'approved'"
                        decoration-warning="state == 'confirmed'"
                        decoration-danger="state == 'rejected'"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>

        <!-- Vista formulario -->
        <record id="view_zonaweb_bidding_request_form" model="ir.ui.view">
            <field name="name">zonaweb.bidding.request.form</field>
            <field name="model">zonaweb.bidding.request</field>
            <field name="arch" type="xml">
                <form string="Solicitud de Licitación">
                    <header>
                        <button name="action_confirm" type="object" string="Confirmar"
                            class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve" type="object" string="Aprobar"
                            class="btn-success" invisible="state != 'confirmed'"/>
                        <button name="action_reject" type="object" string="Rechazar"
                            class="btn-danger" invisible="state not in ['draft', 'confirmed']"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,confirmed,approved,rejected"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_name"/>
                                <field name="contact_name"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </group>
                            <group>
                                <field name="service_type"/>
                                <field name="estimated_budget"/>
                                <field name="estimated_timeline"/>
                                <field name="company_sector"/>
                            </group>
                        </group>
                        <group>
                            <field name="project_description"/>
                            <field name="specific_requirements"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Vista kanban — t-name="card" es el estándar Odoo 17+ -->
        <record id="view_zonaweb_bidding_request_kanban" model="ir.ui.view">
            <field name="name">zonaweb.bidding.request.kanban</field>
            <field name="model">zonaweb.bidding.request</field>
            <field name="arch" type="xml">
                <kanban string="Solicitudes de Licitación">
                    <field name="name"/>
                    <field name="company_name"/>
                    <field name="contact_name"/>
                    <field name="email"/>
                    <field name="state"/>
                    <templates>
                        <t t-name="card">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_record_subtitle">
                                        <field name="company_name"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="contact_name"/><br/>
                                <field name="email"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'approved'"
                                        decoration-warning="state == 'confirmed'"
                                        decoration-danger="state == 'rejected'"
                                        decoration-muted="state == 'draft'"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Acción de ventana -->
        <record id="action_zonaweb_bidding_request" model="ir.actions.act_window">
            <field name="name">Solicitudes de Licitación</field>
            <field name="res_model">zonaweb.bidding.request</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crea tu primera solicitud de licitación
                </p>
                <p>
                    Las solicitudes se crearán automáticamente desde el formulario del sitio web.
                </p>
            </field>
        </record>

        <!-- Menú backend -->
        <menuitem id="menu_zonaweb_bidding" name="Licitaciones"
            parent="sale.sale_menu_root" sequence="10"/>
        <menuitem id="menu_zonaweb_bidding_requests" name="Solicitudes"
            parent="menu_zonaweb_bidding"
            action="action_zonaweb_bidding_request" sequence="10"/>
    </data>
</odoo>