<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="zonaweb_homepage" name="Zonaweb Homepage">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <!-- Hero Section -->
                <section class="hero-section">
                    <div class="container">
                        <div class="hero-content">
                            <h1 class="hero-title">Soluciones Informáticas<br/>Profesionales para tu Empresa</h1>
                            <p class="hero-subtitle">Desarrollo de software, infraestructura de redes, soporte técnico y seguridad informática para impulsar tu negocio</p>
                            
                            <div class="image-carousel">
                                <div class="carousel-slide active">
                                    <img src="/zonaweb_website/static/src/img/hero1.jpg" alt="Equipo de desarrollo de software"/>
                                </div>
                                <div class="carousel-slide">
                                    <img src="/zonaweb_website/static/src/img/hero2.jpg" alt="Infraestructura de redes"/>
                                </div>
                                <div class="carousel-slide">
                                    <img src="/zonaweb_website/static/src/img/hero3.jpg" alt="Seguridad informática"/>
                                </div>
                                <div class="carousel-indicators">
                                    <div class="carousel-indicator active" data-slide="0"></div>
                                    <div class="carousel-indicator" data-slide="1"></div>
                                    <div class="carousel-indicator" data-slide="2"></div>
                                </div>
                            </div>
                            
                            <a href="/contactus" class="cta-button">Contactar ahora</a>
                        </div>
                    </div>
                </section>
                
                <!-- Services Section -->
                <section class="services-section">
                    <div class="container">
                        <h2 class="section-title">Nuestros Servicios</h2>
                        <div class="services-grid">
                            <div class="service-card">
                                <div class="service-image">
                                    <img src="/zonaweb_website/static/src/img/service1.jpg" alt="Desarrollo de software"/>
                                </div>
                                <div class="service-content">
                                    <div class="service-icon">
                                        <i class="fa fa-code"></i>
                                    </div>
                                    <h3 class="service-title">Desarrollo de Software</h3>
                                    <p class="service-description">Creamos soluciones a medida para optimizar tus procesos de negocio.</p>
                                    <a href="/services/software" class="service-link">Saber más <i class="fa fa-arrow-right"></i></a>
                                </div>
                            </div>
                            
                            <div class="service-card">
                                <div class="service-image">
                                    <img src="/zonaweb_website/static/src/img/service2.jpg" alt="Infraestructura de redes"/>
                                </div>
                                <div class="service-content">
                                    <div class="service-icon">
                                        <!-- fa-network-wired es FA5, se reemplaza por fa-sitemap (FA4) -->
                                        <i class="fa fa-sitemap"></i>
                                    </div>
                                    <h3 class="service-title">Infraestructura de Redes</h3>
                                    <p class="service-description">Diseñamos redes robustas y seguras para tu empresa.</p>
                                    <a href="/services/infrastructure" class="service-link">Saber más <i class="fa fa-arrow-right"></i></a>
                                </div>
                            </div>
                            
                            <div class="service-card">
                                <div class="service-image">
                                    <img src="/zonaweb_website/static/src/img/service3.jpg" alt="Soporte técnico"/>
                                </div>
                                <div class="service-content">
                                    <div class="service-icon">
                                        <i class="fa fa-headset"></i>
                                    </div>
                                    <h3 class="service-title">Soporte Técnico</h3>
                                    <p class="service-description">Asistencia remota y presencial para resolver problemas.</p>
                                    <a href="/services/support" class="service-link">Saber más <i class="fa fa-arrow-right"></i></a>
                                </div>
                            </div>
                            
                            <div class="service-card">
                                <div class="service-image">
                                    <img src="/zonaweb_website/static/src/img/service4.jpg" alt="Seguridad informática"/>
                                </div>
                                <div class="service-content">
                                    <div class="service-icon">
                                        <!-- fa-shield-alt es FA5, se reemplaza por fa-shield (FA4) -->
                                        <i class="fa fa-shield"></i>
                                    </div>
                                    <h3 class="service-title">Seguridad Informática</h3>
                                    <p class="service-description">Protegemos tus activos digitales con soluciones avanzadas.</p>
                                    <a href="/services/security" class="service-link">Saber más <i class="fa fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Portfolio Section -->
                <section class="portfolio-section">
                    <div class="container">
                        <h2 class="section-title">Proyectos Recientes</h2>
                        <div class="portfolio-grid">
                            <div class="portfolio-card">
                                <div class="portfolio-image">
                                    <img src="/zonaweb_website/static/src/img/project1.jpg" alt="Proyecto TMS"/>
                                </div>
                                <div class="portfolio-content">
                                    <h3 class="portfolio-title">TMS - Sistema de Gestión</h3>
                                    <p class="portfolio-description">Sistema integral para gestión de transporte y logística.</p>
                                </div>
                            </div>
                            
                            <div class="portfolio-card">
                                <div class="portfolio-image">
                                    <img src="/zonaweb_website/static/src/img/project2.jpg" alt="Proyecto Reservas 360"/>
                                </div>
                                <div class="portfolio-content">
                                    <h3 class="portfolio-title">Reservas 360</h3>
                                    <p class="portfolio-description">Plataforma de reservas online con pagos integrados.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Plans Section -->
                <section class="plans-section">
                    <div class="container">
                        <h2 class="section-title">Planes de Seguridad</h2>
                        <div class="plans-grid">
                            <div class="plan-card">
                                <div class="plan-price">$49</div>
                                <h3 class="plan-title">Plan Estándar</h3>
                                <ul class="plan-features">
                                    <li class="plan-feature">
                                        <!-- fa-check-circle-o es la variante FA4 -->
                                        <i class="fa fa-check-circle-o"></i>
                                        <span>Protección antivirus básica</span>
                                    </li>
                                    <li class="plan-feature">
                                        <i class="fa fa-check-circle-o"></i>
                                        <span>Soporte técnico por correo</span>
                                    </li>
                                    <li class="plan-feature">
                                        <i class="fa fa-check-circle-o"></i>
                                        <span>Actualizaciones mensuales</span>
                                    </li>
                                </ul>
                                <a href="/shop/product/standard-plan" class="plan-button">Comprar ahora</a>
                            </div>
                            
                            <div class="plan-card">
                                <div class="plan-price">$79</div>
                                <h3 class="plan-title">Plan Premium</h3>
                                <ul class="plan-features">
                                    <li class="plan-feature">
                                        <i class="fa fa-check-circle-o"></i>
                                        <span>Protección antivirus avanzada</span>
                                    </li>
                                    <li class="plan-feature">
                                        <i class="fa fa-check-circle-o"></i>
                                        <span>Soporte técnico 24/7</span>
                                    </li>
                                    <li class="plan-feature">
                                        <i class="fa fa-check-circle-o"></i>
                                        <span>Actualizaciones en tiempo real</span>
                                    </li>
                                </ul>
                                <a href="/shop/product/premium-plan" class="plan-button">Comprar ahora</a>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Bidding Banner -->
                <section class="bidding-banner">
                    <div class="container">
                        <div class="bidding-content">
                            <div class="bidding-info">
                                <h2 class="bidding-title">¿Necesitas una solución personalizada?</h2>
                                <p class="bidding-text">Solicita una licitación y nuestro equipo te contactará con una propuesta adaptada a tus necesidades.</p>
                            </div>
                            <a href="/licencias" class="bidding-button">Solicitar Licitación</a>
                        </div>
                    </div>
                </section>
                
                <!-- Testimonials Section -->
                <section class="testimonials-section">
                    <div class="container">
                        <h2 class="section-title">Testimonios</h2>
                        <div class="testimonial-card">
                            <p class="testimonial-text">"Zonaweb transformó completamente nuestra infraestructura tecnológica. Su equipo profesional nos ayudó a optimizar procesos y mejorar la seguridad."</p>
                            <div class="testimonial-author">
                                <div class="author-avatar">JD</div>
                                <div class="author-info">
                                    <div class="author-name">Juan Díaz</div>
                                    <div class="author-position">Director de TI, Empresa XYZ</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
    
    <!-- Bidding Page -->
    <template id="bidding_page" name="Bidding Page">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="bidding-hero">
                    <div class="container">
                        <h1>Solicitar Licitación</h1>
                        <p>Obtén una propuesta personalizada para tus necesidades de servicios informáticos</p>
                    </div>
                </section>
                
                <section class="bidding-process">
                    <div class="container">
                        <h2>Nuestro Proceso de Licitación</h2>
                        <div class="process-steps">
                            <div class="step">
                                <div class="step-number">1</div>
                                <h3>Envío de Solicitud</h3>
                                <p>Completa el formulario con los detalles de tu proyecto</p>
                            </div>
                            <div class="step">
                                <div class="step-number">2</div>
                                <h3>Confirmación</h3>
                                <p>Recibirás confirmación en menos de 24 horas</p>
                            </div>
                            <div class="step">
                                <div class="step-number">3</div>
                                <h3>Análisis de Requisitos</h3>
                                <p>Nuestro equipo analiza tus necesidades específicas</p>
                            </div>
                            <div class="step">
                                <div class="step-number">4</div>
                                <h3>Propuesta Detallada</h3>
                                <p>Recibes una propuesta completa con plazos y costos</p>
                            </div>
                            <div class="step">
                                <div class="step-number">5</div>
                                <h3>Aprobación e Inicio</h3>
                                <p>Al aprobar, iniciamos el proyecto inmediatamente</p>
                            </div>
                        </div>
                    </div>
                </section>
                
                <section class="bidding-form-section">
                    <div class="container">
                        <h2>Formulario de Licitación</h2>
                        <form action="/submit-bidding" method="post" class="bidding-form">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Nombre de la Empresa *</label>
                                    <input type="text" name="company_name" class="form-control" required="required"/>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Nombre de Contacto *</label>
                                    <input type="text" name="contact_name" class="form-control" required="required"/>
                                </div>
                            </div>
                            
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Correo Electrónico *</label>
                                    <input type="email" name="email" class="form-control" required="required"/>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Teléfono</label>
                                    <input type="tel" name="phone" class="form-control"/>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">Tipo de Servicio *</label>
                                <select name="service_type" class="form-control" required="required">
                                    <option value="">Selecciona un tipo de servicio</option>
                                    <option value="software">Desarrollo de Software</option>
                                    <option value="infrastructure">Infraestructura de Redes</option>
                                    <option value="support">Soporte Técnico</option>
                                    <option value="security">Seguridad Informática</option>
                                    <option value="other">Otro</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">Descripción del Proyecto *</label>
                                <textarea name="project_description" class="form-control" rows="5" required="required"></textarea>
                            </div>
                            
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Presupuesto Estimado</label>
                                    <input type="number" name="estimated_budget" class="form-control" step="0.01" min="0"/>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Plazo Estimado</label>
                                    <select name="estimated_timeline" class="form-control">
                                        <option value="">Selecciona un plazo</option>
                                        <option value="urgent">Urgente (menos de 1 mes)</option>
                                        <option value="normal">Normal (1-3 meses)</option>
                                        <option value="flexible">Flexible (más de 3 meses)</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">Sector de la Empresa</label>
                                <select name="company_sector" class="form-control">
                                    <option value="">Selecciona un sector</option>
                                    <option value="retail">Retail</option>
                                    <option value="manufacturing">Manufactura</option>
                                    <option value="services">Servicios</option>
                                    <option value="technology">Tecnología</option>
                                    <option value="healthcare">Salud</option>
                                    <option value="education">Educación</option>
                                    <option value="finance">Finanzas</option>
                                    <option value="other">Otro</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">Requisitos Específicos</label>
                                <textarea name="specific_requirements" class="form-control" rows="3"></textarea>
                            </div>
                            
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-lg">Enviar Solicitud</button>
                            </div>
                        </form>
                    </div>
                </section>
            </div>
        </t>
    </template>
    
    <!-- Bidding Thank You Page -->
    <template id="bidding_thankyou" name="Bidding Thank You">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <section class="thank-you-section">
                    <div class="container">
                        <div class="thank-you-content">
                            <i class="fa fa-check-circle fa-4x text-success"></i>
                            <h1>¡Solicitud Recibida!</h1>
                            <p>Tu solicitud de licitación ha sido recibida exitosamente. Nuestro equipo la revisará y te contactará en menos de 24 horas.</p>
                            <p><strong>Número de referencia:</strong> <span t-out="bidding_id"/></p>
                            <a href="/" class="btn btn-primary">Volver al Inicio</a>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
    
    <!-- Página personalizada Zonaweb -->
    <record id="zonaweb_homepage_page" model="website.page">
        <field name="name">Zonaweb Homepage</field>
        <field name="url">/</field>
        <field name="view_id" ref="zonaweb_homepage"/>
        <field name="website_published">True</field>
        <field name="is_homepage">True</field>
    </record>
</odoo>